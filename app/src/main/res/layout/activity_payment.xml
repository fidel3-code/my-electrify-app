<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:context=".Payment"
    app:cardBackgroundColor="#C3C2C2"
    app:cardElevation="15dp"
    app:cardCornerRadius="37dp"
    android:layout_margin="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="15dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="Make Payments"
            android:textAlignment="center"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:background="@drawable/shape"
            android:padding="10dp"/>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="90dp"
        android:src="@drawable/cart"
        android:id="@+id/product_photo"
        android:layout_margin="30dp"
        android:drawableTint="#54ACF4"
      />

    <TextView
        android:id="@+id/product_name"
        android:layout_width="245dp"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:text="Product Name"
        android:textColor="#54ACF4"
        android:textStyle="bold"
        android:textSize="30sp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="This is an amazing product at an affordable price"
            android:textSize="15sp"
            android:textColor="#000000"
            android:id="@+id/product_description"/>

    <TextView
        android:id="@+id/product_cost"
        android:layout_width="137dp"
        android:layout_height="wrap_content"
        android:layout_margin="5dp"
        android:text="Ksh 0"
        android:textColor="#EB1F1F"
        android:textSize="20sp" />

    <EditText
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Enter phone 254XXXXXXXXX"
        android:id="@+id/phone"
        android:textColor="#A09D9D"
        android:background="@drawable/edittext"
        android:padding="12dp"
        android:layout_margin="5dp"/>

    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:id="@+id/pay"
        android:text="PAY NOW"
        android:backgroundTint="#54ACF4"
        android:padding="10dp"
        android:layout_margin="30dp"/>

    </LinearLayout>



</androidx.cardview.widget.CardView>